# ══════════════════════════════════════════════════════
# Math Research Agent - 模型配置
# 支持 OpenAI 兼容 API 和 Anthropic 原生 API
# 复制此文件为 .env 并填入你的配置
# ══════════════════════════════════════════════════════

# ── 必填项 ──

# # 后端类型: "openai" (默认, 推荐) 或 "anthropic"
# LLM_PROVIDER=openai

# # API 密钥
# API_KEY=sk-xxx

# # API 基础地址
# BASE_URL=https://coding.dashscope.aliyuncs.com/v1

# # 主模型名称
# MODEL=qwen3.5-plus

# ── 可选: 分级模型配置 ──
# 证明辅助用的轻量模型 (默认同主模型)
# PROOF_MODEL=qwen3-coder-flash

# ══════════════════════════════════════════════════════
# 各平台配置示例 (取消注释你要用的平台)
# ══════════════════════════════════════════════════════

# ── 阿里云百炼 Coding Plan (千问系列, 推荐) ──
LLM_PROVIDER=openai
API_KEY=sk-sp-xxx
BASE_URL=https://coding.dashscope.aliyuncs.com/v1
MODEL=qwen3.5-plus
PROOF_MODEL=qwen3-coder-flash
# 可选模型: qwen3-max, qwen3.5-plus, qwen3.5-flash, qwen3-coder-plus, qwen3-coder-next

# ── Anthropic 官方 ──
# LLM_PROVIDER=anthropic
# API_KEY=sk-ant-xxx
# BASE_URL=
# MODEL=claude-sonnet-4-6
# PROOF_MODEL=claude-haiku-4-5-20251001

# ── OpenRouter (OpenAI 兼容) ──
# LLM_PROVIDER=openai
# API_KEY=sk-or-xxx
# BASE_URL=https://openrouter.ai/api/v1
# MODEL=anthropic/claude-sonnet-4-6

# ── DeepSeek ──
# LLM_PROVIDER=openai
# API_KEY=sk-xxx
# BASE_URL=https://api.deepseek.com/v1
# MODEL=deepseek-chat

# ── 本地模型 (Ollama, vLLM 等) ──
# LLM_PROVIDER=openai
# API_KEY=ollama
# BASE_URL=http://localhost:11434/v1
# MODEL=llama3

# ══════════════════════════════════════════════════════
# 向后兼容: 以下旧变量名仍可用
# ANTHROPIC_API_KEY, ANTHROPIC_BASE_URL, ANTHROPIC_MODEL
# ══════════════════════════════════════════════════════
